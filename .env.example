# ── RESIDENCE V.G — Variabili d'ambiente ──────────────────────────────────────
# Copia questo file in .env.local per lo sviluppo locale
# NON committare mai .env.local su git

# ── SITO ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.vgresidence.com
NEXT_PUBLIC_SITE_NAME=Residence V.G

# ── GOOGLE ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-17576720313
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=   # opzionale — per embed mappa Google
GOOGLE_SITE_VERIFICATION=          # codice verifica Google Search Console (meta tag)

# ── ANALYTICS ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_COOKIEYES_ID=           # ID CookieYes se usato
NEXT_PUBLIC_GTM_ID=                 # Google Tag Manager ID (opzionale)

# ── DATABASE TRACKING (server-side — opzionale) ───────────────────────────────
# Necessario solo se si usa il tracking MySQL su Hostinger
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# ── EMAIL ────────────────────────────────────────────────────────────────────
# Per le API di invio form contatti
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=info@vgresidence.com
CONTACT_RECIPIENT=info@vgresidence.com

# ── SVILUPPO ─────────────────────────────────────────────────────────────────
NODE_ENV=development
